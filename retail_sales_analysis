CREATE DATABASE retail;
USE retail;
CREATE TABLE sales_info(
	transactions_id INT PRIMARY KEY, 
	sale_date DATE,
	sale_time TIME,
	customer_id INT,
	gender VARCHAR(15),
	age	INT,
    category VARCHAR(50),
	quantiy INT,
	price_per_unit FLOAT,
	cogs FLOAT,
    total_sale FLOAT
    );

SELECT * FROM retail.sales_info;
SELECT COUNT(*)
FROM sales_info;

-- DATA CLEANING
SELECT * FROM sales_info
WHERE
    transactions_id IS NULL
        OR sale_date IS NULL
        OR sale_time IS NULL
        OR customer_id IS NULL
        OR gender IS NULL
        OR age IS NULL
        OR category IS NULL
        OR quantiy IS NULL
        OR price_per_unit IS NULL
        OR cogs IS NULL
        OR total_sale IS NULL;
        
-- if null present then use
DELETE FROM sales_info
WHERE
    transactions_id IS NULL
        OR sale_date IS NULL
